# Curaiva AI MCP Server — Environment Variables
# Copy this to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── FHIR Configuration ────────────────────────────────────────────────────────
# Default FHIR base URL (used when SHARP context doesn't provide one)
# Public test servers:
#   HAPI FHIR R4:     https://hapi.fhir.org/baseR4
#   Smile CDR:        https://lforms-fhir.nlm.nih.gov/baseR4
#   Aidbox:           (your sandbox URL)
DEFAULT_FHIR_BASE_URL=https://hapi.fhir.org/baseR4

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Optional: Auth ────────────────────────────────────────────────────────────
# These are typically passed per-request via SHARP context, not set globally.
# Set here only for development testing against a protected FHIR server.
# FHIR_ACCESS_TOKEN=your-token-here
