# Curaiva AI — Web App Environment Variables
# Copy to .env.local and fill in your values
# NEVER commit .env.local to version control

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── MCP Server ────────────────────────────────────────────────────────────────
# URL of your deployed MCP server (Railway)
# Use http://localhost:3001 for local development
MCP_SERVER_URL=https://curaiva-ai-mcp.railway.app

# ── Anthropic (used by API routes that call Claude directly, if any) ──────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://curaiva-ai.vercel.app
NODE_ENV=development
